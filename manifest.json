{
    "manifest_version": 3,
    "name": "SIMKULIAH Login Bot",
    "version": "1.0.0",
    "description": "Log in to SIMKULIAH instantly with a bot without having to fill in the CAPTCHA verification code",
    "permissions": ["activeTab", "scripting", "storage"],
    "host_permissions": ["https://api-inference.huggingface.co/*"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "32": "icons/32x32.png",
            "48": "icons/48x48.png",
            "64": "icons/64x64.png"
        }
    },
    "icons": {
        "32": "icons/32x32.png",
        "48": "icons/48x48.png",
        "64": "icons/64x64.png",
        "128": "icons/128x128.png",
        "256": "icons/256x256.png"
    }
}
